# Production / Render — MongoDB Atlas + Groq
SECRET_KEY=change-this-to-a-long-random-string
GROQ_API_KEY=your_groq_api_key_here
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/causesense?retryWrites=true&w=majority
DB_NAME=causesense
CORS_ORIGINS=https://causesenseai.com,https://www.causesenseai.com,https://causesense-web.onrender.com
# Public frontend URL (used in password-reset links)
FRONTEND_URL=https://causesense-web.onrender.com
# When SMTP is unset, API returns reset_url in the response (set false in production with email)
PASSWORD_RESET_RETURN_TOKEN=true
# Optional SMTP for email reset links
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@causesenseai.com
# SMTP_TLS=true
# Frontend build (Render static site) — set to your API URL:
REACT_APP_BACKEND_URL=https://causesense-api.onrender.com
